{
  "expo": {
    "name": "smart-waste-mobile",
    "slug": "smart-waste-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "smartwastemobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#001828"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bryanortiz.smartwastemobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Necesitamos acceso a la cámara para detectar acumulaciones de basura."
      }
    },
    "android": {
      "package": "com.bryanortiz.smartwastemobile",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Necesitamos tu ubicación para registrar dónde está la basura."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#001828",
          "dark": {
            "backgroundColor": "#001828"
          }
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Necesitamos acceso a la cámara para detectar acumulaciones de basura.",
          "enableFrameProcessors": true
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c259a64b-d63f-4a3d-bc7f-a9afcded7a48"
      }
    },
    "owner": "bryanandreso",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c259a64b-d63f-4a3d-bc7f-a9afcded7a48"
    }
  }
}
