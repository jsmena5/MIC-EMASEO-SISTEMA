# ============================================================
# Variables requeridas por docker-compose.yml
# Copia este archivo como .env y rellena los valores reales.
# NUNCA comitees el .env con credenciales reales.
# ============================================================

# ── MinIO (Object Storage) ────────────────────────────────────────────────────
# Cambia estos valores por credenciales seguras antes de levantar en producción.
MINIO_ROOT_USER=cambia_este_usuario
MINIO_ROOT_PASSWORD=cambia_esta_clave_segura_minimo_8_chars

# ── ML Service ───────────────────────────────────────────────────────────────
# "false" para inferencia real (requiere rtdetr_l_best.pt en ML/modelos/).
# "true"  para modo dummy/demo sin modelo.
DUMMY_MODE=false

# ── CORS (api-gateway) ───────────────────────────────────────────────────────
# Orígenes permitidos separados por coma.
# En desarrollo: http://localhost:5173
# En producción: https://tu-dominio.com
CORS_ORIGINS=http://localhost:5173
