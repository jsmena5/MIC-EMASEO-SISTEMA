# ============================================================
# MIC EMASEO — Variables de entorno
# ============================================================
# 1. Copia este archivo: cp .env.example .env
# 2. Reemplaza CADA valor <...> con un secreto real.
# 3. NUNCA subas .env al repositorio (ya está en .gitignore).
#
# Generación rápida de secretos:
#   openssl rand -base64 24    → contraseñas de 32 chars
#   openssl rand -base64 48    → JWT_SECRET (64 chars)
#   openssl rand -base64 32    → INTERNAL_TOKEN (43 chars)
#
# O ejecuta el asistente incluido:
#   bash scripts/generate_env.sh
# ============================================================

# ── PostgreSQL (superusuario del contenedor) ──────────────────────────────────
# POSTGRES_USER es el superusuario creado al inicializar el volumen.
# POSTGRES_PASSWORD NO debe ser "postgres" ni ningún valor por defecto conocido.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<generar con: openssl rand -base64 24>
POSTGRES_DB=MIC-EMASEO

# ── Roles de servicio (mínimo privilegio) ─────────────────────────────────────
# Cada microservicio se conecta con su propio rol de base de datos.
# Estos valores deben coincidir con lo configurado en
# Backend/database/012_db_users_isolation.sh (script de init de Postgres).
#
# Usuarios creados por el script de init — no cambiar los nombres de usuario
# salvo que también actualices el SQL de bootstrap.
DB_USER_AUTH=auth_svc
DB_PASSWORD_AUTH=<generar con: openssl rand -base64 24>

DB_USER_USERS=users_svc
DB_PASSWORD_USERS=<generar con: openssl rand -base64 24>

DB_USER_IMAGE=image_svc
DB_PASSWORD_IMAGE=<generar con: openssl rand -base64 24>

# ── JWT ───────────────────────────────────────────────────────────────────────
# Secreto compartido entre API Gateway y Auth Service para firmar/verificar
# los access tokens. Usar mínimo 48 bytes de entropía.
JWT_SECRET=<generar con: openssl rand -base64 48>
# Duración del access token. Formato: https://github.com/vercel/ms
# Usada por auth-service (login/refresh/reset-password) y users-service (set-password).
# No cambiar a valores mayores de 15m en producción (el refresh token gestiona la sesión larga).
JWT_EXPIRES_IN=15m

# Coste de bcrypt para hashing de contraseñas. 12 es el mínimo recomendado en 2026.
# Subir a 14 si el hardware lo permite (cada +1 = 2x más lento).
BCRYPT_ROUNDS=12

# ── Postgres SSL ──────────────────────────────────────────────────────────────
# En desarrollo local con Postgres en docker: false.
# En producción con Supabase / RDS / Cloud SQL: true.
DB_SSL=false

# ── MinIO (Object Storage S3-compatible) ──────────────────────────────────────
# Credenciales del usuario root de MinIO.
# MINIO_ROOT_PASSWORD debe tener al menos 8 caracteres.
MINIO_ROOT_USER=emaseo_admin
MINIO_ROOT_PASSWORD=<generar con: openssl rand -base64 24>

# Configuración del bucket (sin credenciales — valores de infraestructura)
S3_BUCKET=emaseo-incidents
S3_REGION=us-east-1
# URL pública a la que apuntarán las URLs de las imágenes subidas.
# En desarrollo: http://localhost:9000
# En producción: URL pública de tu S3/MinIO (ej. https://storage.emaseo.ec)
S3_PUBLIC_URL=http://localhost:9000

# ── Redis ─────────────────────────────────────────────────────────────────────
# Contraseña de Redis (requirepass). Dejar vacío desactiva la autenticación,
# lo que NO es aceptable fuera de entornos de prueba aislados.
REDIS_PASSWORD=<generar con: openssl rand -base64 24>

# ── SMTP (envío de correos transaccionales) ───────────────────────────────────
# Usado por Auth Service para OTPs de registro y recuperación de contraseña.
SMTP_HOST=smtp.tudominio.com
SMTP_PORT=587
SMTP_USER=notificaciones@emaseo.ec
SMTP_PASS=<contraseña del buzón SMTP>
EMAIL_FROM=notificaciones@emaseo.ec

# ── Seguridad interna (X-Internal-Token) ─────────────────────────────────────
# Header que el API Gateway inyecta en cada petición a los microservicios.
# Cada servicio rechaza con 403 cualquier petición que no lo lleve.
# Rotar este valor junto con JWT_SECRET en caso de compromiso.
INTERNAL_TOKEN=<generar con: openssl rand -base64 32>

# ── CORS (API Gateway) ────────────────────────────────────────────────────────
# Orígenes permitidos separados por coma.
# Desarrollo: http://localhost:5173
# Producción: https://tu-dominio.com
CORS_ORIGINS=http://localhost:5173

# ── ML Service ────────────────────────────────────────────────────────────────
# false → inferencia real (requiere ML/modelos/rtdetr_l_best.pt)
# true  → modo dummy/demo sin modelo (responde siempre con has_waste: true)
DUMMY_MODE=false

# ── Flower (dashboard Celery) ─────────────────────────────────────────────────
# Credenciales para la autenticación básica HTTP de Flower.
# En producción elimina el mapeo de puerto o pon Flower detrás de un proxy TLS.
FLOWER_USER=admin
FLOWER_PASSWORD=<generar con: openssl rand -base64 24>

# ── Puertos de desarrollo ─────────────────────────────────────────────────────
# Controla la publicación de puertos de MinIO (9000, 9001), Redis (6379) y
# Flower (5555) en el host mediante expansión de variable en docker-compose.yml:
#
#   ports:
#     - "${EXPOSE_DEV_PORTS:+127.0.0.1:9000:9000}"
#
# Semántica de ${VAR:+value} (shell/Compose):
#   - Vacío o sin definir → la entrada se expande a cadena vacía → puerto NO publicado
#   - Cualquier valor no vacío (p. ej. "true") → puerto publicado en 127.0.0.1
#
# IMPORTANTE: el valor "false" es una cadena no vacía, por lo que SÍ publicaría
# los puertos. Para deshabilitarlos en producción, deja la variable vacía (sin valor).
#
# En DESARROLLO: EXPOSE_DEV_PORTS=true   ← permite mc, redis-cli, RedisInsight, etc.
# En PRODUCCIÓN: EXPOSE_DEV_PORTS=       ← vacío; la comunicación usa emaseo_network
#
# Los healthchecks y la comunicación interna no usan puertos del host en ningún caso.
EXPOSE_DEV_PORTS=
