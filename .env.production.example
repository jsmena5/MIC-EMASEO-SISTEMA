# ============================================================
# .env.production.example
# ============================================================
# Plantilla del .env para despliegue en VPS con servicios managed
# (Supabase + Cloudflare R2). Copia este archivo a .env y rellena.
#
#   cp .env.production.example .env
#   # editar .env con credenciales reales
#   docker compose -f docker-compose.prod.yml up -d
#
# NUNCA subas el .env real al repositorio.
# ============================================================

# ── Entorno ───────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── PostgreSQL (Supabase managed) ─────────────────────────────────────────────
# Connection string del pooler (transaction mode = puerto 6543, session = 5432).
# Roles creados manualmente en Supabase con CREATE ROLE + GRANTs equivalentes
# al script Backend/database/012_db_users_isolation.sh.
DB_HOST=<project>.pooler.supabase.com
DB_PORT=6543
DB_NAME=postgres
DB_SSL=true

DB_USER_AUTH=auth_svc
DB_PASSWORD_AUTH=<contraseña-auth-svc>

DB_USER_USERS=users_svc
DB_PASSWORD_USERS=<contraseña-users-svc>

DB_USER_IMAGE=image_svc
DB_PASSWORD_IMAGE=<contraseña-image-svc>

# ── JWT / Seguridad interna ───────────────────────────────────────────────────
JWT_SECRET=<openssl rand -base64 48>
JWT_EXPIRES_IN=15m
BCRYPT_ROUNDS=12
INTERNAL_TOKEN=<openssl rand -base64 32>

# ── Object Storage (Cloudflare R2 — S3 compatible) ────────────────────────────
# Credenciales: R2 → Manage R2 API tokens → Create Token con Object Read & Write.
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_BUCKET=emaseo-incidents
S3_ACCESS_KEY_ID=<r2-access-key>
S3_SECRET_ACCESS_KEY=<r2-secret-key>
S3_REGION=auto
# Custom domain del bucket (ej. https://storage.emaseo.ec). Las URLs públicas
# de imágenes en la DB se sirven desde aquí.
S3_PUBLIC_URL=https://storage.tu-dominio.ec

# ── Redis (auto-hosted en el mismo VPS) ───────────────────────────────────────
# Si migras a Redis managed (Upstash, ElastiCache), reemplaza el endpoint
# en docker-compose.prod.yml por la URL externa.
REDIS_PASSWORD=<openssl rand -base64 24>
# REDIS_PASSWORD con '+' → %2B, '/' → %2F, '=' → %3D (necesario en URLs).
REDIS_PASSWORD_ENCODED=<el mismo valor pero URL-encoded>

# ── SMTP (servicio transaccional recomendado: SendGrid, Resend, Mailgun) ──────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=<api-key>
EMAIL_FROM=notificaciones@tu-dominio.ec

# ── Dominios públicos ─────────────────────────────────────────────────────────
# URL del gateway accesible públicamente (vía reverse proxy con TLS).
PUBLIC_API_URL=https://api.tu-dominio.ec
# Orígenes permitidos (panel web + cualquier dominio cliente).
CORS_ORIGINS=https://panel.tu-dominio.ec

# ── ML Service ────────────────────────────────────────────────────────────────
DUMMY_MODE=false
PRE_CHECK_THRESHOLD=0.35

# ── Flower (dashboard Celery) ─────────────────────────────────────────────────
# Si se expone, hacerlo SIEMPRE detrás de proxy con TLS + autenticación.
FLOWER_USER=admin
FLOWER_PASSWORD=<openssl rand -base64 24>

# ── Build / Registry ──────────────────────────────────────────────────────────
# Si usas imágenes pre-construidas (GHCR / Docker Hub), ajusta REGISTRY y TAG.
# Si usas builds locales (compose build), déjalos por defecto.
REGISTRY=ghcr.io/tu-org
TAG=latest
