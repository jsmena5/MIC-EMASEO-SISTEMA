*.pid
*.seed

# ── Dumps de base de datos (nunca versionar — pueden contener datos) ───────────
backups/
*.sql
*.dump
*.sqlite
*.db

# Excepción: las migraciones SÍ se versionan (son DDL, no dumps con datos).
# Sin esto, cada migración nueva quedaba ignorada por *.sql y requería git add -f,
# causando drift entre el schema de producción y el versionado.
!Backend/database/migrations/
!Backend/database/migrations/*.sql
!Backend/database/seeds/
!Backend/database/seeds/*.sql

# ── Docker ─────────────────────────────────────────────────────────────────────
docker-compose.override.yml
.dockerignore

# ── Artefactos generados de entrenamiento ML ───────────────────────────────────
ML/logs/
ML/reporte_labels.txt

