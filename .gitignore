# ── Pesos de modelos (archivos grandes — almacenados en OneDrive/Drive) ────────
*.pt
*.onnx
*.engine
*.pth

# ── Carpetas generadas por Ultralytics ─────────────────────────────────────────
runs/

# ── Python ─────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# ── Entornos virtuales ─────────────────────────────────────────────────────────
venv*/
.venv/
env/

# ── Variables de entorno (secretos) ────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Node.js ────────────────────────────────────────────────────────────────────
node_modules/

# ── Expo / React Native ────────────────────────────────────────────────────────
.expo/
dist/
build/
*.orig.*
web-build/

# ── Herramientas del IDE ────────────────────────────────────────────────────────
.vscode/
.idea/
.claude/

# ── Sistema operativo ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Dumps de base de datos (nunca versionar — pueden contener datos) ───────────
backups/

# ── Artefactos generados de entrenamiento ML (logs/reportes, no código) ────────
ML/logs/
ML/reporte_labels.txt

# ── Datos temporales de desarrollo (caches, blobs binarios) ─────────────────
_*.b64
_*_cache.json
*.pytest_cache/

.deploy_creds*

# ── Reportes de cobertura y análisis (generados localmente, no versionar) ──────
coverage/
.scannerwork/
