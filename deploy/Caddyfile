# =============================================================================
# Caddyfile — reverse proxy con TLS automático (Let's Encrypt) para el VPS.
#
# Coloca este archivo en /etc/caddy/Caddyfile del VPS.
# Caddy se encarga de:
#   - Obtener y renovar certificados Let's Encrypt automáticamente
#   - Redirigir HTTP → HTTPS
#   - Terminar TLS antes del API Gateway (que escucha solo en 127.0.0.1:4000)
#
# Después de cambios:  sudo systemctl reload caddy
# =============================================================================

# API Gateway — único punto de entrada del backend
api.tu-dominio.ec {
	encode zstd gzip

	# Cabeceras de seguridad básicas (Helmet ya cubre la mayoría, pero las
	# repetimos en el proxy por si algún endpoint nuevo las omite).
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options    nosniff
		X-Frame-Options           DENY
		Referrer-Policy           strict-origin-when-cross-origin
		# CSP lo gestiona el frontend; aquí solo evitamos que el gateway envíe
		# inline scripts. Si el OpenAPI UI lo necesita, ajustar localmente.
	}

	# Rate limit lo gestiona el gateway (rate-limit-redis); Caddy solo enruta.
	reverse_proxy 127.0.0.1:4000 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}

# Supervisor panel — si lo despliegas en el mismo VPS (en lugar de Vercel/Pages)
panel.tu-dominio.ec {
	encode zstd gzip

	# El container del panel (nginx) escucha en 127.0.0.1:8080.
	# Levántalo con: docker run -d -p 127.0.0.1:8080:80 ghcr.io/tu-org/supervisor-panel:latest
	reverse_proxy 127.0.0.1:8080

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options    nosniff
		X-Frame-Options           DENY
		Referrer-Policy           strict-origin-when-cross-origin
	}
}

