# ============================================================
# API Gateway — variables de entorno
# ============================================================
# Este archivo solo se usa si corres el gateway FUERA de Docker
# (npm run dev). En Docker, las variables vienen del .env raíz
# vía docker-compose.yml.
#
# 1. Copia: cp .env.example .env
# 2. Reemplaza CADA valor <...> con un secreto real.
# 3. NUNCA subas .env al repositorio.
# ============================================================

PORT=4000
NODE_ENV=development

# ── Seguridad ─────────────────────────────────────────────────────────────────
# Mismo valor que en .env raíz / auth-service / users-service.
JWT_SECRET=<generar con: openssl rand -base64 48>
# Header X-Internal-Token que el gateway inyecta en cada llamada interna.
INTERNAL_TOKEN=<generar con: openssl rand -base64 32>

# ── URLs internas de microservicios ───────────────────────────────────────────
# En Docker Compose se reemplazan por nombres de servicio (http://auth-service:3002, etc.).
# En desarrollo nativo (npm run dev) apuntan a localhost.
AUTH_SERVICE_URL=http://localhost:3002
USERS_SERVICE_URL=http://localhost:3000
IMAGE_SERVICE_URL=http://localhost:5000
ML_SERVICE_URL=http://localhost:8000

# URL interna de MinIO/R2 — usada por el proxy /api/media del gateway.
# Dentro de Docker: http://minio:9000
# Con Cloudflare R2: https://<account-id>.r2.cloudflarestorage.com
MINIO_INTERNAL_URL=http://localhost:9000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Lista separada por comas. En desarrollo: panel web Vite (5173) y el propio gateway.
# En producción: dominios reales (https://panel.emaseo.ec, etc.).
CORS_ORIGINS=http://localhost:5173,http://localhost:4000

# ── Rate limit distribuido (opcional) ─────────────────────────────────────────
# Si se define, el rate limit usa Redis y es coherente entre múltiples réplicas
# del gateway. Si no, usa memoria local (no apto para escalar horizontalmente).
# REDIS_URL=redis://:<password>@localhost:6379/1

# ── Swagger / OpenAPI ─────────────────────────────────────────────────────────
# URL pública del gateway — la que los clientes verán en /api-docs.
# En producción debe ser HTTPS (ej. https://api.emaseo.ec).
PUBLIC_API_URL=http://localhost:4000
